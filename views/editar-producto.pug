extends layout

block content
  .container(style="display: flex; justify-content: center; align-items: center; min-height: 70vh; padding: 0;")
    .card(style="width: 100%; max-width: 500px; padding: 2.5rem; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);")
      div(style="text-align: center; margin-bottom: 2rem;")
        h2(style="font-size: 1.75rem; font-weight: 700; color: var(--text-main); margin-bottom: 0.5rem;") Editar Producto
        p(style="color: var(--text-muted); font-size: 0.95rem;") Modificá los datos del producto

      #error-container(style="display: none; background-color: #fee2e2; border: 1px solid #fca5a5; color: #b91c1c; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 500;")

      form#editar-producto-form
        .form-group(style="margin-bottom: 1.25rem;")
          label(for="codigo" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Código
          input#codigo(
            type="text" 
            name="codigo" 
            placeholder="PROD-001" 
            required 
            value=producto.codigo
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        .form-group(style="margin-bottom: 1.25rem;")
          label(for="nombre" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Nombre
          input#nombre(
            type="text" 
            name="nombre" 
            placeholder="Producto" 
            required 
            value=producto.nombre
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        .form-group(style="margin-bottom: 1.25rem;")
          label(for="precio" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Precio
          input#precio(
            type="number" 
            name="precio" 
            placeholder="0" 
            step="0.01" 
            min="0.01" 
            required 
            value=producto.precio
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        .form-group(style="margin-bottom: 1.25rem;")
          label(for="stock" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Stock
          input#stock(
            type="number" 
            name="stock" 
            placeholder="0" 
            min="0" 
            required 
            value=producto.stock
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        .form-group(style="margin-bottom: 1.25rem;")
          label(for="descripcion" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Descripción
          textarea#descripcion(
            name="descripcion"
            placeholder="Descripción del producto (opcional)"
            rows="3"
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; resize: vertical; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )= producto.descripcion

        .form-group(style="margin-bottom: 1.25rem;")
          label(for="imagen" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") URL de Imagen
          input#imagen(
            type="url"
            name="imagen"
            placeholder="https://ejemplo.com/imagen.jpg (opcional)"
            value=producto.imagen || ''
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )
          #imagen-preview(style="margin-top: 0.75rem; display: " + (producto.imagen ? 'block' : 'none') + ";")
            img(src=producto.imagen || '' style="max-width: 100%; max-height: 180px; border-radius: 8px; border: 1px solid var(--border); object-fit: cover;")

        .form-group(style="margin-bottom: 1.75rem;")
          label(for="tienda" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Tienda
          select#tienda(
            name="tienda"
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none; background: var(--card-bg); cursor: pointer;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )
            option(value="") Sin tienda
            each tienda in tiendas
              option(value=tienda._id selected=(producto.tienda && producto.tienda.toString() === tienda._id.toString()))= tienda.nombre

        div(style="display: flex; gap: 1rem;")
          a.btn(href="/vistas/productos" style="flex: 1; text-align: center; border: 1px solid var(--border); color: var(--text-muted); padding: 0.75rem; font-size: 1rem; box-sizing: border-box;") Cancelar
          button.btn.btn-primary(
            type="submit" 
            style="flex: 2; padding: 0.75rem; border: none; font-size: 1rem; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 0.5rem; box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);"
          ) Guardar Cambios

  script.
    document.getElementById('editar-producto-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const errorContainer = document.getElementById('error-container');
      errorContainer.style.display = 'none';
      errorContainer.textContent = '';
      
      const codigo = document.getElementById('codigo').value;
      const nombre = document.getElementById('nombre').value;
      const precio = document.getElementById('precio').value;
      const stock = document.getElementById('stock').value;
      const descripcion = document.getElementById('descripcion').value;
      const tienda = document.getElementById('tienda').value;
      
      const imagen = document.getElementById('imagen').value;
      const bodyData = { codigo, nombre, precio, stock, descripcion };
      if (tienda) bodyData.tienda = tienda;
      if (imagen) bodyData.imagen = imagen;
      
      try {
        const response = await fetch('/productos/#{producto._id}', {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + localStorage.getItem('token')
          },
          body: JSON.stringify(bodyData)
        });
        
        const data = await response.json();
        
        if (!response.ok) {
          throw new Error(data.error || 'Ocurrió un error al actualizar el producto.');
        }
        
        showToast('Producto actualizado correctamente', 'success');
        setTimeout(function() {
          window.location.href = '/vistas/productos';
        }, 1000);
        
      } catch (err) {
        errorContainer.textContent = err.message;
        errorContainer.style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    document.getElementById('imagen').addEventListener('input', function() {
      const preview = document.getElementById('imagen-preview');
      const img = preview.querySelector('img');
      const url = this.value.trim();
      if (url) {
        img.src = url;
        preview.style.display = 'block';
      } else {
        preview.style.display = 'none';
        img.src = '';
      }
    });

    document.querySelector('#imagen-preview img').addEventListener('error', function() {
      this.style.display = 'none';
      var fallback = document.createElement('div');
      fallback.textContent = 'No se pudo cargar la imagen';
      fallback.style.cssText = 'padding: 2rem; text-align: center; color: var(--text-muted); background: #f8fafc; border-radius: 8px; border: 1px solid var(--border); font-size: 0.85rem;';
      this.parentNode.appendChild(fallback);
    });

    document.querySelector('#imagen-preview img').addEventListener('load', function() {
      this.style.display = '';
      var existing = this.parentNode.querySelector('div:last-child');
      if (existing && existing.tagName === 'DIV') existing.remove();
    });
