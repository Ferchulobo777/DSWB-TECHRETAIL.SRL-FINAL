doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title TechRetail Admin
    link(rel="stylesheet" href="/css/style.css")
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet")
    script.
      (function() {
        const token = localStorage.getItem('token');
        const path = window.location.pathname;
        const isLoginPage = path === '/login' || path === '/vistas/login';
        
        if (!token && !isLoginPage) {
          window.location.href = '/login';
        } else if (token && isLoginPage) {
          window.location.href = '/vistas';
        }
      })();
  body
    header
      .nav-content
        a.logo(href="/") TechRetail
        nav.nav-links(style="display: flex; align-items: center;")
          a(href="/vistas/usuarios") Usuarios
          a(href="/vistas/productos") Productos
          a(href="/vistas/tiendas") Tiendas
          a(href="/vistas/pedidos") Pedidos
          #nav-session-container(style="display: inline-block; margin-left: 1.5rem;")
    
    .container
      block content
    
    footer
      .container(style="text-align: center; color: var(--text-muted); margin-top: 4rem;")
        p &copy; 2024 TechRetail Srl - Panel de Administración

    #toast-container

    script.
      document.addEventListener('DOMContentLoaded', function() {
        const sessionContainer = document.getElementById('nav-session-container');
        if (!sessionContainer) return;

        const userJson = localStorage.getItem('user');
        const user = userJson ? JSON.parse(userJson) : null;

        if (user && user.nombre) {
          // Generar dropdown interactivo para el usuario logueado
          sessionContainer.innerHTML = `
            <div class="dropdown" id="user-dropdown">
              <div class="dropdown-btn" id="user-dropdown-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <span>Hola, ${escapeHtml(user.nombre.split(' ')[0])}</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="dropdown-content">
                <a href="#" id="logout-btn" class="logout-link" style="display: flex; align-items: center; gap: 0.5rem;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                  Salir
                </a>
              </div>
            </div>
          `;

          // Control interactivo del desplegable al hacer clic
          const dropdown = document.getElementById('user-dropdown');
          const dropdownBtn = document.getElementById('user-dropdown-btn');

          dropdownBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdown.classList.toggle('active');
          });

          // Cerrar dropdown si se hace clic fuera de él
          document.addEventListener('click', function() {
            dropdown.classList.remove('active');
          });

          // Lógica de cerrar sesión (Salir)
          document.getElementById('logout-btn').addEventListener('click', function(e) {
            e.preventDefault();
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/login';
          });

        } else {
          // Mostrar enlace normal para iniciar sesión
          sessionContainer.innerHTML = `
            <a href="/login" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.9rem; font-weight: 500; text-decoration: none;">Iniciar Sesión</a>
          `;
        }

        function escapeHtml(str) {
          return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
        }

        window.showToast = function(message, type) {
          const container = document.getElementById('toast-container');
          if (!container) return;

          const toast = document.createElement('div');
          toast.className = 'toast toast-' + (type || 'success');
          toast.textContent = message;
          container.appendChild(toast);

          setTimeout(function() {
            toast.classList.add('toast-hiding');
            setTimeout(function() {
              if (toast.parentNode) toast.parentNode.removeChild(toast);
            }, 300);
          }, 3000);
        };
      });
