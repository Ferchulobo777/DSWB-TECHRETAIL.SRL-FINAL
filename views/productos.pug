extends layout

block content
  header(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; background: none; border: none; box-shadow: none; padding: 0;")
    h1 Productos
    a.btn.btn-primary(href="/vistas/productos/nuevo") + Nuevo Producto

  .card
    .search-bar(style="margin-bottom: 1rem;")
      input#searchInput(type="text" placeholder="Buscar por nombre, código o tienda..." style="width: 100%; max-width: 480px; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.95rem;")

    table
      thead
        tr
          th Código
          th Nombre
          th Precio
          th Stock
          th Tienda
          th Descripción
          th Acciones
      tbody
        each producto in productos
          tr.product-row(data-search=`${producto.codigo} ${producto.nombre} ${producto.tienda ? producto.tienda.nombre : ''}`)
            td(style="font-family: monospace; font-weight: 600;")= producto.codigo
            td(style="font-weight: 600;")= producto.nombre
            td= `$${producto.precio.toLocaleString()}`
            td
              span(style=producto.stock < 5 ? "color: #ef4444; font-weight: 700;" : "")= producto.stock
            td(style="font-size: 0.85rem; color: var(--text-muted);")= producto.tienda ? producto.tienda.nombre : "—"
            td(style="color: var(--text-muted); font-size: 0.875rem;")= producto.descripcion || "—"
            td
              a(href=`/vistas/productos/editar/${producto._id}` style="color: var(--primary); text-decoration: none; margin-right: 1rem;") Editar
              button.btn-delete(data-id=`${producto._id}` style="background: none; border: none; color: #ef4444; cursor: pointer; font-family: inherit; font-size: inherit; padding: 0;") Eliminar
        else
          tr
            td(colspan="7" style="text-align: center; padding: 2rem;") No hay productos registrados.

  script.
    const searchInput = document.getElementById('searchInput');
    const rows = Array.from(document.querySelectorAll('.product-row'));

    function filtrarProductos() {
      const query = (searchInput?.value || '').trim().toLowerCase();

      rows.forEach(function(row) {
        const searchText = (row.getAttribute('data-search') || '').toLowerCase();
        row.style.display = searchText.includes(query) ? '' : 'none';
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', filtrarProductos);
    }

    document.querySelectorAll('.btn-delete').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        const id = this.getAttribute('data-id');
        if (!confirm('¿Estás seguro de eliminar este producto?')) return;

        const token = localStorage.getItem('token');
        try {
          const response = await fetch('/productos/' + id, {
            method: 'DELETE',
            headers: { 'Authorization': 'Bearer ' + token }
          });
          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || 'Error al eliminar el producto.');
          }

          showToast('Producto eliminado correctamente', 'success');
          this.closest('tr').remove();
        } catch (err) {
          showToast(err.message, 'error');
        }
      });
    });
