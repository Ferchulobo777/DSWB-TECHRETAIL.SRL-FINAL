extends public-layout

block content
  .store-hero
    div
      h1= tienda.nombre
      p.store-address= tienda.direccion
    a.btn.btn-outline(href="/vistas/tiendas" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem;")
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
        polyline(points="15 18 9 12 15 6")
      | Todas las tiendas

  if productos.length === 0
    .card(style="text-align: center; padding: 3rem;")
      p(style="color: var(--text-muted);") No hay productos disponibles en esta tienda.
  else
    .products-grid
      each prod in productos
        .product-card
          if prod.imagen
            .product-img(style=`background-image: url(${prod.imagen})`)
          else
            .product-img.product-img-placeholder
              svg(width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); opacity: 0.4;")
                rect(x="3" y="3" width="18" height="18" rx="2" ry="2")
                circle(cx="8.5" cy="8.5" r="1.5")
                polyline(points="21 15 16 10 5 21")
          .product-body
            h3.product-name= prod.nombre
            if prod.descripcion
              p.product-desc= prod.descripcion
            .product-footer
              span.product-price $#{prod.precio.toFixed(2)}
              span.product-stock(class=(prod.stock === 0 ? 'agotado' : ''))
                if prod.stock === 0
                  | Agotado
                else
                  = prod.stock + ' en stock'
            button.btn.add-to-cart(
              class=(prod.stock === 0 ? 'btn-disabled' : 'btn-primary')
              data-id=prod._id.toString()
              data-nombre=prod.nombre
              data-precio=prod.precio
              disabled=(prod.stock === 0)
            ) Agregar al carrito

  button#cart-fab.cart-fab
    svg(width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
      circle(cx="9" cy="21" r="1")
      circle(cx="20" cy="21" r="1")
      path(d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6")
    span#cart-count.cart-count 0

  #cart-overlay.cart-overlay
    .cart-sidebar
      .cart-header
        h2 Carrito
        button#cart-close.cart-close &times;
      #cart-items.cart-items
        p(style="color: var(--text-muted); text-align: center; padding: 2rem;") El carrito está vacío.
      .cart-total
        .cart-total-row
          span Total
          span#cart-total-amount $0.00
        button#checkout-btn.btn.btn-primary(style="width: 100%; padding: 0.85rem; border: none; font-size: 1rem; cursor: pointer;") Finalizar Compra

  #checkout-overlay.checkout-overlay(style="display: none;")
    .checkout-modal
      .checkout-header
        h2 Finalizar Compra
        button#checkout-close.checkout-close &times;
      .checkout-body
        .form-group
          label(for="usuario-select") Seleccionar Usuario
          select#usuario-select(required style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); font-family: inherit; font-size: 0.95rem; background: white;")
            option(value="") Cargando usuarios...
        h3(style="margin-top: 1.5rem; margin-bottom: 0.75rem; font-size: 1rem;") Resumen del Pedido
        #checkout-summary.checkout-summary
        .checkout-total
          span Total
          span#checkout-total-amount $0.00
      .checkout-footer
        button#cancel-checkout.btn(style="border: 1px solid var(--border); background: none; padding: 0.75rem 1.5rem; border-radius: 8px; cursor: pointer; font-family: inherit; font-size: 0.95rem;") Cancelar
        button#confirm-checkout.btn.btn-primary(style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; cursor: pointer; font-family: inherit; font-size: 0.95rem;") Confirmar Pedido

  #checkout-success-overlay(style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 10000; display: none; align-items: center; justify-content: center;")
    .card(style="text-align: center; padding: 3rem; max-width: 400px;")
      svg(width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
        path(d="M22 11.08V12a10 10 0 1 1-5.93-9.14")
        polyline(points="22 4 12 14.01 9 11.01")
      h2(style="margin: 1rem 0 0.5rem;") Pedido Confirmado
      p#success-message(style="color: var(--text-muted);") Tu pedido ha sido registrado.
      a.btn.btn-primary(href="/vistas/tiendas" style="margin-top: 1.5rem; text-decoration: none; display: inline-block;") Volver a Tiendas

  script.
    var slug = '#{tienda.slug}';
    var cart = {};

    document.addEventListener('DOMContentLoaded', function() {
      var usuarios = !{JSON.stringify(usuarios)};
      var select = document.getElementById('usuario-select');
      select.innerHTML = '<option value="">Seleccionar usuario...</option>';
      usuarios.forEach(function(u) {
        var opt = document.createElement('option');
        opt.value = u._id;
        opt.textContent = u.nombre + ' ' + (u.apellido || '') + ' (' + u.email + ')';
        select.appendChild(opt);
      });

      document.querySelectorAll('.add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = this.getAttribute('data-id');
          var nombre = this.getAttribute('data-nombre');
          var precio = parseFloat(this.getAttribute('data-precio'));
          addToCart(id, nombre, precio);
        });
      });

      document.getElementById('cart-fab').addEventListener('click', function() {
        document.getElementById('cart-overlay').classList.add('open');
      });

      document.getElementById('cart-close').addEventListener('click', function() {
        document.getElementById('cart-overlay').classList.remove('open');
      });

      document.getElementById('checkout-btn').addEventListener('click', function() {
        if (Object.keys(cart).length === 0) {
          showToast('El carrito está vacío', 'error');
          return;
        }
        document.getElementById('cart-overlay').classList.remove('open');
        openCheckout();
      });

      document.getElementById('checkout-close').addEventListener('click', closeCheckout);
      document.getElementById('cancel-checkout').addEventListener('click', closeCheckout);

      document.getElementById('confirm-checkout').addEventListener('click', confirmCheckout);
    });

    function addToCart(id, nombre, precio) {
      if (cart[id]) {
        cart[id].cantidad++;
      } else {
        cart[id] = { nombre: nombre, precio: precio, cantidad: 1 };
      }
      updateCartUI();
      showToast(nombre + ' agregado al carrito', 'success');
    }

    function removeFromCart(id) {
      delete cart[id];
      updateCartUI();
    }

    function changeQuantity(id, delta) {
      if (!cart[id]) return;
      cart[id].cantidad += delta;
      if (cart[id].cantidad <= 0) {
        delete cart[id];
      }
      updateCartUI();
    }

    function getCartCount() {
      var count = 0;
      for (var id in cart) {
        count += cart[id].cantidad;
      }
      return count;
    }

    function getCartTotal() {
      var total = 0;
      for (var id in cart) {
        total += cart[id].precio * cart[id].cantidad;
      }
      return total;
    }

    function updateCartUI() {
      var count = getCartCount();
      document.getElementById('cart-count').textContent = count;

      var container = document.getElementById('cart-items');
      var keys = Object.keys(cart);

      if (keys.length === 0) {
        container.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 2rem;">El carrito está vacío.</p>';
        document.getElementById('cart-total-amount').textContent = '$0.00';
        return;
      }

      var html = '';
      for (var i = 0; i < keys.length; i++) {
        var id = keys[i];
        var item = cart[id];
        html += '<div class="cart-item">';
        html += '  <div class="cart-item-info">';
        html += '    <div class="cart-item-name">' + item.nombre + '</div>';
        html += '    <div class="cart-item-price">$' + (item.precio * item.cantidad).toFixed(2) + '</div>';
        html += '  </div>';
        html += '  <div class="cart-item-qty">';
        html += '    <button class="qty-btn" onclick="changeQuantity(\'' + id + '\', -1)">-</button>';
        html += '    <span>' + item.cantidad + '</span>';
        html += '    <button class="qty-btn" onclick="changeQuantity(\'' + id + '\', 1)">+</button>';
        html += '    <button class="remove-btn" onclick="removeFromCart(\'' + id + '\')">&times;</button>';
        html += '  </div>';
        html += '</div>';
      }
      container.innerHTML = html;
      document.getElementById('cart-total-amount').textContent = '$' + getCartTotal().toFixed(2);
    }

    function openCheckout() {
      var summary = document.getElementById('checkout-summary');
      var keys = Object.keys(cart);
      var html = '';
      for (var i = 0; i < keys.length; i++) {
        var id = keys[i];
        var item = cart[id];
        html += '<div class="checkout-item">';
        html += '  <span>' + item.nombre + ' x' + item.cantidad + '</span>';
        html += '  <span>$' + (item.precio * item.cantidad).toFixed(2) + '</span>';
        html += '</div>';
      }
      summary.innerHTML = html;
      document.getElementById('checkout-total-amount').textContent = '$' + getCartTotal().toFixed(2);
      document.getElementById('checkout-overlay').style.display = 'flex';
    }

    function closeCheckout() {
      document.getElementById('checkout-overlay').style.display = 'none';
    }

    async function confirmCheckout() {
      var select = document.getElementById('usuario-select');
      var usuarioId = select.value;

      if (!usuarioId) {
        showToast('Seleccioná un usuario', 'error');
        return;
      }

      var productos = [];
      for (var id in cart) {
        productos.push({ productoId: id, cantidad: cart[id].cantidad });
      }

      document.getElementById('confirm-checkout').disabled = true;
      document.getElementById('confirm-checkout').textContent = 'Procesando...';

      try {
        var res = await fetch('/tienda/' + slug + '/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ usuarioId: usuarioId, productos: productos })
        });
        var data = await res.json();
        if (!res.ok) {
          throw new Error(data.error || 'Error al crear el pedido');
        }
        closeCheckout();
        cart = {};
        updateCartUI();
        document.getElementById('success-message').textContent = 'Pedido #' + data.numeroOrden + ' confirmado correctamente.';
        document.getElementById('checkout-success-overlay').style.display = 'flex';
      } catch (err) {
        showToast(err.message, 'error');
        document.getElementById('confirm-checkout').disabled = false;
        document.getElementById('confirm-checkout').textContent = 'Confirmar Pedido';
      }
    }
