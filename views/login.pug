extends layout

block content
  .container(style="display: flex; justify-content: center; align-items: center; min-height: 60vh; padding: 0;")
    .card(style="width: 100%; max-width: 420px; padding: 2.5rem; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);")
      div(style="text-align: center; margin-bottom: 2rem;")
        h2(style="font-size: 1.75rem; font-weight: 700; color: var(--text-main); margin-bottom: 0.5rem;") Bienvenido
        p(style="color: var(--text-muted); font-size: 0.95rem;") Inicia sesión para acceder al panel administrativo

      #error-container(style="display: none; background-color: #fee2e2; border: 1px solid #fca5a5; color: #b91c1c; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 500;")

      form#login-form
        .form-group(style="margin-bottom: 1.25rem;")
          label(for="email" style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.9rem;") Correo electrónico
          input#email(
            type="email" 
            name="email" 
            placeholder="ejemplo@techretail.com" 
            required 
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        .form-group(style="margin-bottom: 1.75rem;")
          div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;")
            label(for="password" style="font-weight: 500; color: var(--text-main); font-size: 0.9rem;") Contraseña
            a(href="#" style="font-size: 0.8rem; color: var(--primary); text-decoration: none; font-weight: 500;") ¿La olvidaste?
          input#password(
            type="password" 
            name="password" 
            placeholder="••••••••" 
            required 
            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); box-sizing: border-box; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s; outline: none;"
            onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 3px rgba(37, 99, 235, 0.1)';"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
          )

        button.btn.btn-primary(
          type="submit" 
          style="width: 100%; padding: 0.75rem; border: none; font-size: 1rem; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 0.5rem; box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);"
        ) Iniciar sesión

      div(style="text-align: center; margin-top: 1.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem;")
        p(style="font-size: 0.875rem; color: var(--text-muted); margin: 0;") 
          | ¿No tienes cuenta? 
          a(href="/vistas/usuarios/nuevo" style="color: var(--primary); text-decoration: none; font-weight: 600;") Solicita acceso

  // Sticky Note de Credenciales Demo
  .demo-note(
    style="position: fixed; bottom: -82px; right: 2rem; width: 280px; background-color: #fffbeb; border: 1.5px solid #fef08a; border-radius: 12px 12px 0 0; box-shadow: 0 -4px 15px -3px rgba(251, 191, 36, 0.15), 0 -2px 6px -4px rgba(251, 191, 36, 0.1); padding: 1rem 1rem 0.75rem 1rem; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; z-index: 10000; box-sizing: border-box;"
    onmouseover="this.style.transform='translateY(-82px)';"
    onmouseout="this.style.transform='translateY(0)';"
  )
    div(style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; border-bottom: 1.5px solid #fef08a; padding-bottom: 0.5rem;")
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round")
        circle(cx="7.5" cy="15.5" r="5.5")
        path(d="M21 2L11.5 11.5")
        path(d="M17 17l4-4")
        path(d="M15.5 8.5l3 3")
      span(style="font-size: 0.8rem; font-weight: 800; color: #b45309; text-transform: uppercase; letter-spacing: 0.05em;") Acceso Demo
    div(style="font-size: 0.85rem; color: #78350f; line-height: 1.5;")
      p(style="margin: 0 0 0.35rem 0;") 
        strong Correo: 
        span(style="font-family: monospace; background: rgba(253, 224, 71, 0.2); padding: 0.1rem 0.25rem; border-radius: 4px;") admin@gmail.com
      p(style="margin: 0 0 0.75rem 0;") 
        strong Clave: 
        span(style="font-family: monospace; background: rgba(253, 224, 71, 0.2); padding: 0.1rem 0.25rem; border-radius: 4px;") admin123
      button#btn-autofill(
        type="button"
        style="width: 100%; background: #fef08a; border: 1.5px solid #facc15; color: #a16207; font-size: 0.8rem; font-weight: 700; padding: 0.45rem; border-radius: 6px; cursor: pointer; transition: background 0.2s, transform 0.1s;"
        onmouseover="this.style.background='#fef9c3';"
        onmouseout="this.style.background='#fef08a';"
        onmousedown="this.style.transform='scale(0.97)';"
        onmouseup="this.style.transform='scale(1)';"
      ) Autocompletar datos

  script.
    document.getElementById('login-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const errorContainer = document.getElementById('error-container');
      errorContainer.style.display = 'none';
      errorContainer.textContent = '';
      
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      
      try {
        const response = await fetch('/usuarios/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ email, password })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
          throw new Error(data.error || 'Correo o contraseña incorrectos.');
        }
        
        // Guardar en localStorage
        localStorage.setItem('token', data.token);
        localStorage.setItem('user', JSON.stringify(data.usuario));
        
        showToast('Inicio de sesión exitoso', 'success');
        setTimeout(function() {
          window.location.href = '/vistas';
        }, 1000);
        
      } catch (err) {
        errorContainer.textContent = err.message;
        errorContainer.style.display = 'block';
      }
    });

    // Lógica para autocompletar las credenciales demo al pulsar el botón
    document.getElementById('btn-autofill').addEventListener('click', function(e) {
      e.stopPropagation(); // Evitar interferencias con el hover
      document.getElementById('email').value = 'admin@gmail.com';
      document.getElementById('password').value = 'admin123';
    });
